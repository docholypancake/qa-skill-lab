    {
      "name": "TC-RB-001 (BOOK VALID)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response contains bookingid\", function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.have.property(\"bookingid\");",
              "    pm.expect(body.bookingid).to.be.a(\"number\").and.above(0);",
              "});",
              "",
              "pm.test(\"Booking data matches payload\", function () {",
              "    const booking = pm.response.json().booking;",
              "    pm.expect(booking.firstname).to.equal(\"Jim\");",
              "    pm.expect(booking.lastname).to.equal(\"Brown\");",
              "    pm.expect(booking.totalprice).to.equal(111);",
              "    pm.expect(booking.depositpaid).to.equal(true);",
              "    pm.expect(booking.bookingdates.checkin).to.equal(\"2024-01-01\");",
              "    pm.expect(booking.bookingdates.checkout).to.equal(\"2024-01-05\");",
              "    pm.expect(booking.additionalneeds).to.equal(\"Breakfast\");",
              "});",
              "",
              "// Save booking ID for use in read/update/delete requests",
              "pm.environment.set(\"booking_id\", pm.response.json().bookingid);"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"firstname\": \"Jim\",\n    \"lastname\": \"Brown\",\n    \"totalprice\": 111,\n    \"depositpaid\": true,\n    \"bookingdates\": {\n        \"checkin\": \"2024-01-01\",\n        \"checkout\": \"2024-01-05\"\n    },\n    \"additionalneeds\": \"Breakfast\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/booking",
          "host": ["{{base_url}}"],
          "path": ["booking"]
        }
      },
      "response": []
    },
    {
      "name": "TC-RB-005 (READ BOOKING BY ID)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has all 6 fields\", function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.have.property(\"firstname\");",
              "    pm.expect(body).to.have.property(\"lastname\");",
              "    pm.expect(body).to.have.property(\"totalprice\");",
              "    pm.expect(body).to.have.property(\"depositpaid\");",
              "    pm.expect(body).to.have.property(\"bookingdates\");",
              "    pm.expect(body).to.have.property(\"additionalneeds\");",
              "});",
              "",
              "pm.test(\"Response exactly matches booking payload from TC-RB-001\", function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.firstname).to.eql(\"Jim\");",
              "    pm.expect(body.lastname).to.eql(\"Brown\");",
              "    pm.expect(body.totalprice).to.eql(111);",
              "    pm.expect(body.depositpaid).to.eql(true);",
              "    pm.expect(body.bookingdates).to.be.an(\"object\");",
              "    pm.expect(body.bookingdates.checkin).to.eql(\"2024-01-01\");",
              "    pm.expect(body.bookingdates.checkout).to.eql(\"2024-01-05\");",
              "    pm.expect(body.additionalneeds).to.eql(\"Breakfast\");",
              "});"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
